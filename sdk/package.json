{
  "name": "@dixydo/roomkit",
  "version": "0.1.0",
  "description": "Vanilla-JS SDK for embedding self-hosted roomkit video calls into any web page (SFU-based, framework-agnostic).",
  "license": "MIT",
  "author": "Yevhen Kushnir",
  "homepage": "https://github.com/dixydo/roomkit/tree/main/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dixydo/roomkit.git",
    "directory": "sdk"
  },
  "bugs": "https://github.com/dixydo/roomkit/issues",
  "keywords": [
    "webrtc", "video", "video-call", "video-conference",
    "sfu", "roomkit", "real-time", "self-hosted"
  ],
  "type": "module",
  "main": "./dist/roomkit-sdk.umd.cjs",
  "module": "./dist/roomkit-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/roomkit-sdk.js",
      "require": "./dist/roomkit-sdk.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
