# .env.example — copy to .env before first run: make init-env
# All variables are read directly by the roomkit binary (make run).
# Uncomment and fill in only the lines you need — everything has a safe default.

# ---- Server -----------------------------------------------------------------

# HTTP listen address. Default: :8080
ROOMKIT_ADDR=:8080

# Log verbosity: debug | info | warn | error. Default: info
ROOMKIT_LOG_LEVEL=info

# Externally reachable URL of this server — used in local recording download
# links and startup logs. For VPS: https://meet.yourdomain.com
# For local dev leave empty (defaults to http://localhost:8080).
ROOMKIT_PUBLIC_URL=

# Comma-separated origins allowed to open a WebSocket connection.
# Empty = allow any origin (fine for local dev, unsafe for production).
# Example: https://meet.example.com,https://app.example.com
ROOMKIT_ALLOWED_ORIGINS=

# Domain for Caddy TLS (used only in docker-compose + Caddyfile).
DOMAIN=localhost

# Docker image name (change when building from a fork).
# IMAGE=dixydo/roomkit

# ---- Room token auth (optional) -------------------------------------------
# When set, every /ws and /api/ice-config request must carry a signed HS256
# JWT. Leave empty to run in open/unauthenticated mode (fine for local dev
# and trusted networks; always use a token in production).
#
# Generate with: openssl rand -hex 32
# Or run: make init-env   (generates and writes one automatically)
ROOMKIT_ROOM_TOKEN_SECRET=

# Maximum allowed token lifetime in hours. 0 = unlimited (default).
# Recommended: 24 for production deployments.
ROOMKIT_ROOM_TOKEN_MAX_TTL_HOURS=0

# Token format — sign with HMAC-SHA256 (alg=HS256), payload:
#   {
#     "room_id":     "my-room",          // required; must match the room being joined
#     "sub":         "user-123",         // optional; becomes the peer ID
#     "exp":         <unix seconds>,     // required; recommend 1–4 h from now
#     "permissions": ["join", ...]       // required; see below
#   }
#
# Permission strings:
#   "join"          — required to connect (always include)
#   "peer:custom"   — honour the "sub" claim as the peer ID
#   "record:start"  — allowed to trigger recording start
#   "record:stop"   — allowed to trigger recording stop
#
# Example (Node.js):
#   import { createHmac } from 'crypto'
#   const header  = Buffer.from(JSON.stringify({alg:'HS256',typ:'JWT'})).toString('base64url')
#   const payload = Buffer.from(JSON.stringify({
#     room_id: 'my-room', sub: 'user-1',
#     exp: Math.floor(Date.now()/1000) + 3600,
#     permissions: ['join', 'record:start', 'record:stop'],
#   })).toString('base64url')
#   const sig = createHmac('sha256', process.env.ROOMKIT_ROOM_TOKEN_SECRET)
#                 .update(`${header}.${payload}`).digest('base64url')
#   const token = `${header}.${payload}.${sig}`

# ---- ICE / external TURN (optional) ----------------------------------------
# JSON array of ICE servers returned by /api/ice-config.
# When set, REPLACES the default public STUN + embedded TURN response entirely.
# Leave empty to rely on the embedded TURN server configured below.
#
# Example:
# ROOMKIT_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
ROOMKIT_ICE_SERVERS=

# ---- Embedded TURN server (optional) ----------------------------------------
# Relays media for clients behind strict symmetric NATs (~15% of connections).
# Requires a server with a public static IP. Leave ROOMKIT_TURN_PUBLIC_IP
# empty to disable TURN (clients fall back to STUN only).
#
# ROOMKIT_TURN_PUBLIC_IP — the server's public IPv4 address (not a hostname).
#   How to get: curl -s https://ifconfig.me   or check your VPS dashboard.
#
# ROOMKIT_TURN_SECRET — HMAC shared secret for short-lived credential generation.
#   How to get: openssl rand -hex 24
ROOMKIT_TURN_PUBLIC_IP=
ROOMKIT_TURN_SECRET=
ROOMKIT_TURN_PORT=3478
ROOMKIT_TURN_REALM=roomkit
ROOMKIT_TURN_MIN_PORT=49152
ROOMKIT_TURN_MAX_PORT=49200

# ---- Recording (optional) ---------------------------------------------------
# Two modes — pick one:
#
# Mode A: Local storage (simplest, great for dev and self-hosted)
#   Set ROOMKIT_REC_ENABLED=true. ffmpeg must be installed (brew/apt).
#   Recordings are saved to ROOMKIT_REC_WORKDIR and served at /recordings/.
#   Download links use ROOMKIT_PUBLIC_URL so set that too on a VPS.
#
# Mode B: S3-compatible upload (DigitalOcean Spaces, AWS S3, Cloudflare R2…)
#   Fill in the ROOMKIT_S3_* vars below. ROOMKIT_REC_ENABLED is ignored when
#   S3 is configured — S3 takes over automatically.
#
# If neither is set, recording is disabled and the Record button is hidden.

# Mode A — local recording
# Uncomment to enable local recording. Requires ffmpeg: brew install ffmpeg / apt install ffmpeg
# ROOMKIT_REC_ENABLED=true

# Local directory for raw .ivf/.ogg files and the muxed MP4.
# Must be writable by the process running roomkit.
ROOMKIT_REC_WORKDIR=/tmp/roomkit-recordings

# Maximum recording duration per session (hours). Auto-stops when reached.
ROOMKIT_REC_MAX_HOURS=8

# Path to the ffmpeg binary (must be installed separately).
#   macOS:  brew install ffmpeg
#   Ubuntu: apt-get install -y ffmpeg
ROOMKIT_FFMPEG_PATH=ffmpeg

# Mode B — S3-compatible upload (DigitalOcean Spaces example):
#   ROOMKIT_S3_ENDPOINT=https://fra1.digitaloceanspaces.com
#   ROOMKIT_S3_REGION=fra1
#   ROOMKIT_S3_BUCKET=my-roomkit-recordings
#   ROOMKIT_S3_ACCESS_KEY=DOxxxxxxxxxxxxxxxxxx
#   ROOMKIT_S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   ROOMKIT_S3_PUBLIC_BASE=https://my-roomkit-recordings.fra1.cdn.digitaloceanspaces.com
#   ROOMKIT_S3_OBJECT_ACL=              ← leave empty; DO Spaces uses bucket policy
#
# AWS S3:
#   ROOMKIT_S3_ENDPOINT=              ← leave empty for AWS
#   ROOMKIT_S3_REGION=us-east-1
#   ROOMKIT_S3_BUCKET=my-bucket
#   ROOMKIT_S3_ACCESS_KEY=AKIAxxxxxxxxxxxxxxxx
#   ROOMKIT_S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   ROOMKIT_S3_PUBLIC_BASE=https://my-bucket.s3.amazonaws.com
#   ROOMKIT_S3_OBJECT_ACL=public-read
ROOMKIT_S3_ENDPOINT=
ROOMKIT_S3_REGION=us-east-1
ROOMKIT_S3_BUCKET=
ROOMKIT_S3_ACCESS_KEY=
ROOMKIT_S3_SECRET_KEY=
ROOMKIT_S3_PUBLIC_BASE=
ROOMKIT_S3_OBJECT_ACL=

# Lifetime of presigned S3 download URLs (hours). Only used in S3 mode.
ROOMKIT_REC_PRESIGN_TTL_HOURS=24
