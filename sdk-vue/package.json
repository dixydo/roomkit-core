{
  "name": "@dixydo/roomkit-vue",
  "version": "0.1.0",
  "description": "Vue 3 composable + components for @dixydo/roomkit.",
  "license": "MIT",
  "author": "Yevhen Kushnir",
  "homepage": "https://github.com/dixydo/roomkit/tree/main/sdk-vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dixydo/roomkit.git",
    "directory": "sdk-vue"
  },
  "bugs": "https://github.com/dixydo/roomkit/issues",
  "keywords": ["roomkit", "vue", "vue3", "video-call", "webrtc"],
  "type": "module",
  "main": "./dist/roomkit-vue.umd.cjs",
  "module": "./dist/roomkit-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/roomkit-vue.js",
      "require": "./dist/roomkit-vue.umd.cjs"
    },
    "./dist/roomkit-vue.css": "./dist/roomkit-vue.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "@dixydo/roomkit": "^0.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0",
    "@dixydo/roomkit": "file:../sdk",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
