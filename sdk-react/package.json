{
  "name": "@dixydo/roomkit-react",
  "version": "0.1.0",
  "description": "React hook + components for @dixydo/roomkit.",
  "license": "MIT",
  "author": "Yevhen Kushnir",
  "homepage": "https://github.com/dixydo/roomkit/tree/main/sdk-react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dixydo/roomkit.git",
    "directory": "sdk-react"
  },
  "bugs": "https://github.com/dixydo/roomkit/issues",
  "keywords": ["roomkit", "react", "video-call", "webrtc"],
  "type": "module",
  "main": "./dist/roomkit-react.umd.cjs",
  "module": "./dist/roomkit-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/roomkit-react.js",
      "require": "./dist/roomkit-react.umd.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=17",
    "@dixydo/roomkit": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "@dixydo/roomkit": "file:../sdk",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
